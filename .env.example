# FocusGuard Pro — Environment Variables
# Copy this to .env and fill in your actual values

# Firebase
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_PROJECT_ID=focusguard-pro
FIREBASE_STORAGE_BUCKET=focusguard-pro.appspot.com

# OpenAI (for AI Coaching)
OPENAI_API_KEY=sk-your-openai-key

# RevenueCat (In-App Purchases)
REVENUECAT_API_KEY_ANDROID=rc_android_key
REVENUECAT_API_KEY_IOS=rc_ios_key

# Sentry (Error Tracking — optional)
SENTRY_DSN=https://your-sentry-dsn

# App Configuration
APP_NAME=FocusGuard Pro
APP_VERSION=2.0.0
MIN_SDK_VERSION=24
TARGET_SDK_VERSION=34
IOS_DEPLOYMENT_TARGET=15.0
