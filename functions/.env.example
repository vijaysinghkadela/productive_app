# FocusGuard Pro — Environment Variables
# All secrets should be stored in Google Cloud Secret Manager

# ─── Google Cloud ───
GOOGLE_CLOUD_PROJECT=focusguard-pro
FIREBASE_PROJECT_ID=focusguard-pro
BIGQUERY_DATASET_ID=focusguard_analytics
CLOUD_TASKS_QUEUE_LOCATION=us-central1
JOBS_SERVICE_URL=https://api-us-central1-focusguard-pro.cloudfunctions.net/api/jobs

# ─── Secret Manager Keys (do NOT put actual values here) ───
# These are the secret names in Secret Manager:
# openai-api-key
# revenuecat-api-key
# revenuecat-webhook-secret
# sendgrid-api-key
# twilio-account-sid
# twilio-auth-token
# redis-url
# algolia-api-key
# sentry-dsn
# pagerduty-api-key
# encryption-key

# ─── Non-secret Config ───
TWILIO_PHONE_NUMBER=+1234567890
ALGOLIA_APP_ID=your_algolia_app_id
ADMIN_EMAIL=admin@focusguard.app
ADMIN_UID=admin-uid-placeholder

# ─── Local Development (emulator) ───
FUNCTIONS_EMULATOR=true
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199
