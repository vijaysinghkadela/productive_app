{
  "name": "focusguard-pro-functions",
  "version": "1.0.0",
  "description": "FocusGuard Pro Firebase Cloud Functions",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest --testPathPattern=tests/unit --forceExit",
    "test:integration": "jest --testPathPattern=tests/integration --forceExit",
    "test:e2e": "jest --testPathPattern=tests/e2e --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "serve": "npm run build && firebase emulators:start --only functions,firestore,auth,storage",
    "deploy:staging": "firebase deploy --only functions,firestore,storage --project staging",
    "deploy:prod": "firebase deploy --only functions,firestore,storage --project production",
    "seed": "ts-node scripts/seed.ts",
    "migrate": "ts-node scripts/migrate.ts"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.9.1",
    "@google-cloud/logging": "^11.2.1",
    "@google-cloud/pubsub": "^4.9.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/tasks": "^5.5.1",
    "@sendgrid/mail": "^8.1.4",
    "@sentry/node": "^8.40.0",
    "@types/hpp": "^0.2.7",
    "@types/ioredis": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "express": "^4.21.1",
    "express-xss-sanitizer": "^2.0.1",
    "file-type": "^21.3.0",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^4.9.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.0",
    "isomorphic-dompurify": "^3.0.0",
    "nanoid": "^3.3.7",
    "openai": "^4.73.1",
    "otplib": "^12.0.1",
    "pdfkit": "^0.15.1",
    "qrcode": "^1.5.4",
    "stripe": "^20.4.0",
    "twilio": "^5.3.7",
    "uuid": "^11.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.9",
    "@types/pdfkit": "^0.13.5",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.57.1",
    "firebase-functions-test": "^3.3.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "private": true
}
