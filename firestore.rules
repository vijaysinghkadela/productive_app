rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return request.auth.uid == userId; }
    function isAdmin() { return request.auth.token.admin == true; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isValidUser() { return isAuthenticated() && isEmailVerified(); }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function notDeleted() {
      return getUserDoc().data.accountStatus != 'deleted';
    }

    function hasSubscription(tiers) {
      return getUserDoc().data.subscription.tier in tiers;
    }

    function isAccountabilityPartner(pairId) {
      let pair = get(/databases/$(database)/documents/accountability_pairs/$(pairId));
      return request.auth.uid in pair.data.userIds;
    }

    function isGroupMember(groupId) {
      let group = get(/databases/$(database)/documents/accountability_groups/$(groupId));
      return request.auth.uid in group.data.memberIds;
    }

    function incomingDataHasOnly(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function notChangingRestrictedFields(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ─── Users Collection ───
    match /users/{userId} {
      allow read: if isValidUser() && (isOwner(userId) || isAdmin());

      allow create: if isAuthenticated() && isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.accountStatus == 'active';

      allow update: if isValidUser() && isOwner(userId) && notDeleted()
        && notChangingRestrictedFields([
          'uid', 'email', 'subscription', 'stats.totalXp', 'stats.level',
          'createdAt', 'termsAccepted', 'referralCode'
        ])
        && request.resource.data.updatedAt == request.time;

      allow delete: if false; // Deletion only via Cloud Functions

      // ─── Sessions ───
      match /sessions/{sessionId} {
        allow read: if isValidUser() && isOwner(userId);
        allow create: if isValidUser() && isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.sessionId == sessionId
          && request.resource.data.status in ['active', 'completed']
          && request.resource.data.plannedDurationMinutes is int
          && request.resource.data.plannedDurationMinutes >= 1
          && request.resource.data.plannedDurationMinutes <= 480;
        allow update: if isValidUser() && isOwner(userId)
          && notChangingRestrictedFields(['userId', 'sessionId', 'startedAt', 'createdAt', 'xpEarned'])
          && request.resource.data.updatedAt == request.time;
        allow delete: if false;
      }

      // ─── Daily Stats ───
      match /daily_stats/{date} {
        allow read: if isValidUser() && isOwner(userId);
        allow create, update: if isValidUser() && isOwner(userId)
          && date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
          && request.resource.data.userId == userId
          && request.resource.data.date == date;
        allow delete: if false;
      }

      // ─── Goals ───
      match /goals/{goalId} {
        allow read: if isValidUser() && isOwner(userId);
        allow create, update: if isValidUser() && isOwner(userId)
          && request.resource.data.userId == userId;
        allow delete: if isValidUser() && isOwner(userId);
      }

      // ─── Habits ───
      match /habits/{habitId} {
        allow read: if isValidUser() && isOwner(userId);
        allow create, update: if isValidUser() && isOwner(userId)
          && request.resource.data.userId == userId;
        allow delete: if isValidUser() && isOwner(userId);
      }

      // ─── Achievements (unlocked — write-only via Cloud Functions) ───
      match /achievements/{achievementId} {
        allow read: if isValidUser() && isOwner(userId);
        allow write: if false;
      }

      // ─── Journal ───
      match /journal/{date} {
        allow read: if isValidUser() && isOwner(userId);
        allow create, update: if isValidUser() && isOwner(userId)
          && date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
        allow delete: if false;
      }

      // ─── Notifications (read + mark-read only from client) ───
      match /notifications/{notificationId} {
        allow read: if isValidUser() && isOwner(userId);
        allow update: if isValidUser() && isOwner(userId)
          && incomingDataHasOnly(['read', 'readAt', 'actionTaken']);
        allow create, delete: if false;
      }

      // ─── AI Conversations (Pro/Elite only) ───
      match /ai_conversations/{conversationId} {
        allow read: if isValidUser() && isOwner(userId)
          && hasSubscription(['pro', 'elite', 'lifetime']);
        allow create: if isValidUser() && isOwner(userId)
          && hasSubscription(['pro', 'elite', 'lifetime']);
        allow update: if isValidUser() && isOwner(userId)
          && notChangingRestrictedFields(['userId', 'conversationId', 'createdAt', 'totalTokensUsed']);
        allow delete: if false;
      }

      // ─── Blocking Schedule ───
      match /blocking_schedule/{scheduleId} {
        allow read, write: if isValidUser() && isOwner(userId);
      }

      // ─── Focus Modes ───
      match /focus_modes/{modeId} {
        allow read, write: if isValidUser() && isOwner(userId);
      }
    }

    // ─── Accountability Pairs ───
    match /accountability_pairs/{pairId} {
      allow read: if isValidUser() && isAccountabilityPartner(pairId);
      allow create: if isValidUser()
        && request.auth.uid in request.resource.data.userIds
        && request.resource.data.userIds.size() == 2
        && request.resource.data.status == 'pending';
      allow update: if isValidUser() && isAccountabilityPartner(pairId)
        && notChangingRestrictedFields(['pairId', 'createdAt', 'initiatorId', 'inviteCode'])
        && request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }

    // ─── Accountability Groups ───
    match /accountability_groups/{groupId} {
      allow read: if isValidUser() && isGroupMember(groupId);
      allow create: if isValidUser()
        && request.auth.uid in request.resource.data.memberIds
        && request.auth.uid == request.resource.data.adminId
        && request.resource.data.memberIds.size() <= 6;
      allow update: if isValidUser() && isGroupMember(groupId)
        && (request.auth.uid == resource.data.adminId ||
            incomingDataHasOnly(['memberIds', 'updatedAt']));
      allow delete: if isValidUser() && request.auth.uid == resource.data.adminId;
    }

    // ─── Challenges ───
    match /challenges/{challengeId} {
      allow read: if isValidUser();
      allow write: if isAdmin();
      match /participants/{userId} {
        allow read: if isValidUser();
        allow create: if isValidUser() && isOwner(userId)
          && request.resource.data.status == 'active';
        allow update: if false; // Cloud Functions only
        allow delete: if isValidUser() && isOwner(userId);
      }
    }

    // ─── Leaderboard (read-only for clients) ───
    match /leaderboard/{period}/entries/{userId} {
      allow read: if isValidUser();
      allow write: if false;
    }

    // ─── Global Achievement Definitions ───
    match /achievements/{achievementId} {
      allow read: if isValidUser();
      allow write: if isAdmin();
    }

    // ─── Reports (Cloud Functions only) ───
    match /reports/{reportId} {
      allow read: if isValidUser() && request.auth.uid == resource.data.userId;
      allow write: if false;
    }

    // ─── App Config (public read, admin write) ───
    match /app_config/{configId} {
      allow read: if isValidUser();
      allow write: if isAdmin();
    }

    // ─── Referrals (Cloud Functions only) ───
    match /referrals/{referralCode} {
      allow read: if isValidUser();
      allow write: if false;
    }

    // ─── Admin ───
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    // ─── Webhook Events (dedup, Cloud Functions only) ───
    match /webhook_events/{eventId} {
      allow read, write: if false;
    }

    // ─── Deny everything else ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
