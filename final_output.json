  "code": "def solve(a, K):\n    n = len(a)\n    max_val = float('-inf')\n    for i in range(n):\n        for j in range(i, n):\n            sub = a[i:j+1]\n            val = sum(sub) - K ** len(set(sub))\n            max_val = max(max_val, val)\n    return max_val\n\nimport sys\ninput = sys.stdin.read\ndata = input().split()\nif data:\n    n = int(data[0])\n    K = int(data[1])\n    a = list(map(int, data[2:n+2]))\n    print(solve(a, K))"
